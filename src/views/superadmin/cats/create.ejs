
<div class="container mt-4 col-10">
  <h2 class="mb-4">Create New Category</h2>
  <form action="/superadmin/cats/store" method="POST" enctype="multipart/form-data">
    
    <div class="mb-3">
      <label for="name" class="form-label">Cat Name</label>
      <input type="text" id="name" name="name" class="form-control" required>
      <div id="nameFeedback" class="form-text text-danger"></div>
    </div>

    <div class="mb-3">
      <label for="img" class="form-label">Upload Image</label>
      <input type="file" id="img" name="img" accept="image/*" class="form-control">
      <div id="preview" class="mt-2">
        <img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width:200px; display:none;">
      </div>
    </div>

    <div class="mb-3">
      <label for="document" class="form-label">Upload Document</label>
      <input type="file" id="document" name="document" accept=".pdf,.doc,.docx,.txt,image/*" class="form-control">
    </div>

    <div class="d-flex justify-content-end">
      <button type="submit" id="addrecord" class="btn btn-primary" disabled>Save</button>
    </div>
  </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const nameInput = document.getElementById('name');
    const feedback = document.getElementById('nameFeedback');
    const saveBtn = document.getElementById('addrecord');

    // start disabled
    saveBtn.disabled = true;
    saveBtn.classList.add('disabled-btn');

    nameInput.addEventListener('input', async function () {
        const name = this.value.trim();

        // always disable while checking
        saveBtn.disabled = true;
        saveBtn.classList.add('disabled-btn');

        if (name.length < 2) {
            feedback.textContent = 'Name must be at least 2 characters.';
            return;
        }

        try {
            const res = await fetch('/superadmin/cats/check-name', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            });

            const data = await res.json();

            if (data.exists) {
                feedback.textContent = 'This cat name already exists.';
            } else {
                feedback.textContent = 'Available ✓';
                saveBtn.disabled = false;
                saveBtn.classList.remove('disabled-btn'); // ✅ enable visually
            }

        } catch (err) {
            console.error(err);
            feedback.textContent = 'Error checking name.';
        }
    });
});

const imgInput = document.getElementById('img');
const previewImg = document.getElementById('previewImg');

imgInput.addEventListener('change', function() {
    const file = this.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            previewImg.src = e.target.result;
            previewImg.style.display = 'block';
        };
        reader.readAsDataURL(file);
    } else {
        previewImg.src = '';
        previewImg.style.display = 'none';
    }
});
</script>
