<script>
  window.catid = <%= subcat.catid %>;
  window.subcatId = <%= subcat.id %>;

document.addEventListener('DOMContentLoaded', () => {
  const nameInput = document.getElementById('name');
  const catSelect = document.getElementById('catid');
  const feedback = document.getElementById('nameFeedback');
  const saveBtn = document.getElementById('updaterecord');



    async function validateSubcat() 
    {
        const name = nameInput.value.trim();
        const catid = catSelect.value;


        if (name.length < 2) {
            feedback.textContent = 'Name must be at least 2 characters.';
            saveBtn.disabled = true;
            return;
        }
        if (!catid) {
            feedback.textContent = 'Category is required.';
            saveBtn.disabled = true;
            return;
        }

        try {
            const trimmedName = name.replace(/\s+/g, ' ');
            const res = await fetch('/superadmin/subcats/check-name-update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: trimmedName, catid, excludeId: window.subcatId })
            });

            const data = await res.json();

            if (data.exists) {
            feedback.textContent = 'This subcat already exists under the selected category.';
            saveBtn.disabled = true;
            } else {
            feedback.textContent = 'Available ✓';
            saveBtn.disabled = false;
            }
        } catch (err) {
            console.error(err);
            feedback.textContent = 'Error checking subcat name.';
            saveBtn.disabled = true;
        }
    }



  nameInput.addEventListener('input', validateSubcat);
  // If using Select2
  $('#catid').on('change select2:select', validateSubcat);

});

// Populate categories
document.addEventListener('DOMContentLoaded', async () => {
  const catid = Number(window.catid);
  const catSelect = document.getElementById('catid');

  const url = `/superadmin/cats/dropdownjson`;

  try {
    const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();

    catSelect.innerHTML = '<option value="">-- Select Category --</option>';
    data.cats.forEach(cat => {
      const opt = document.createElement('option');
      opt.value = cat.id;
      opt.textContent = cat.name;
      if (cat.id === catid) opt.selected = true;
      catSelect.appendChild(opt);
    });
  } catch (err) {
    console.error('Error fetching dropdown:', err);
  }
});


const imgInput = document.getElementById('img');
const previewImg = document.getElementById('previewImg');

imgInput.addEventListener('change', function() {
  const file = this.files[0];
  if (file) {
    const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      alert('Invalid file type. Please upload an image (jpg, png, gif, webp).');
      this.value = ''; // clear the input
      previewImg.src = '';
      previewImg.style.display = 'none';
      return;
    }

    const reader = new FileReader();
    reader.onload = function(e) {
      previewImg.src = e.target.result;
      previewImg.style.display = 'block';
    };
    reader.readAsDataURL(file);
  } else {
    previewImg.src = '';
    previewImg.style.display = 'none';
  }
 
});


const docInput = document.getElementById('document');
docInput.addEventListener('change', function() {
    const file = this.files[0];
    if (file) {
        const validTypes = [
            'application/pdf',
            'application/msword',
            'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
            'text/plain',
            'image/gif',
            'image/jpeg',
            'image/png'
        ];
        if (!validTypes.includes(file.type)) {
            alert('Invalid file type. Allowed: PDF, DOC, DOCX, TXT, JPG, PNG.');
            this.value = '';
        }
    }
});



</script>
